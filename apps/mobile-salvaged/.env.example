# Supabase Configuration for Lendlee Mobile App
# Copy this file to .env and fill in your actual API keys

# Get these values from your Supabase Dashboard:
# https://supabase.com/dashboard/project/divwsajiaxklbuehnzek/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY_HERE

# Google Sign-In
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_GOOGLE_IOS_CLIENT_ID_HERE

# App Configuration
APP_NAME=Lendlee
APP_VERSION=1.0.0
